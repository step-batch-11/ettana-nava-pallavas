{
  "tasks": {
    "dev": "deno run --watch -A main.js",
    "start": "deno run -A main.js",
    "test": "deno test -A",
    "watch": "deno test -A --watch",
    "coverage": "deno test --coverage -A",
    "detailed": "deno coverage --detailed",
    "lint": "deno lint",
    "all": "deno task lint && deno task coverage",
    "push": "git pull && git push"
  },
  "imports": {
    "@ashishkujoy/deno-coverage-checker": "jsr:@ashishkujoy/deno-coverage-checker@^0.0.9",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/random": "jsr:@std/random@^0.1.5",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.9",
    "/pages/": "./public/pages/",
    "/assets/": "./public/assets/",
    "taiko": "npm:taiko@^1.4.8"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "nodeModulesDir": "auto",
  "allowScripts": {
    "allow": [],
    "deny": ["npm:fsevents@2.3.3", "npm:taiko@1.4.8"]
  }
}
